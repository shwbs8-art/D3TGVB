# ================================
# Iraq Babylon Minecraft Bot - Environment Variables
# هذا ملفك الفعلي (.env) — عبّي الحقول الفاضية بقيمك الخاصة قبل التشغيل
# ================================

# ---------- إعدادات Minecraft ----------
MC_HOST=X1XC.aternos.me
MC_PORT=18201
MC_USERNAME=IraqBabylon
MC_PASSWORD=
MC_VERSION=1.21.4
MC_AUTH=offline

# تفعيل التسجيل التلقائي / تسجيل الدخول التلقائي (register/login plugins)
MC_AUTO_REGISTER=true
MC_AUTO_LOGIN=true
MC_REGISTER_COMMAND=/register {password} {password}
MC_LOGIN_COMMAND=/login {password}

